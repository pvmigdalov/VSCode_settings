{
    "[python]": {
        "editor.formatOnType": true,
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "workbench.colorTheme": "pustota",
    "notebook.lineNumbers": "on",
    "workbench.startupEditor": "none",
    "terminal.integrated.automationProfile.linux": {
        "path": "/usr/bin/bash"
    },
    "gitlens.currentLine.enabled": false,
    "gitlens.hovers.currentLine.over": "line",
    "dbcode.connections": [
        {
            "connectionId": "bxoNSmL2Pv1b-p4aXORmT",
            "name": "fastapi_ecommerce",
            "driver": "postgres",
            "connectionType": "host",
            "host": "localhost",
            "port": 5432,
            "ssl": false,
            "username": "ecommerce",
            "password": "",
            "savePassword": "secretStorage",
            "connectionTimeout": 30
        },
        {
            "connectionId": "G_SgKQBctd-aParQLOzMo",
            "name": "short_urls",
            "driver": "postgres",
            "connectionType": "host",
            "host": "pg_url_shortener",
            "port": 5433,
            "ssl": false,
            "username": "admin",
            "password": "",
            "savePassword": "secretStorage",
            "database": "short_urls",
            "readOnly": false,
            "postConnectionSqlType": "inline",
            "connectionTimeout": 30
        }
    ],
    "workbench.editorAssociations": {
        "*.csv": "gc-excelviewer-csv-editor"
    },
    "editor.fontFamily": "JetBrains Mono",
    "editor.fontLigatures": true,
    "chat.instructionsFilesLocations": {
        ".github/instructions": true,
        // "/tmp/postman-http-request-post-response.instructions.md": true,
        // "/tmp/postman-http-request-pre-request.instructions.md": true,
        // "/tmp/postman-collections-post-response.instructions.md": true,
        // "/tmp/postman-collections-pre-request.instructions.md": true,
        // "/tmp/postman-folder-post-response.instructions.md": true,
        // "/tmp/postman-folder-pre-request.instructions.md": true
    },
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "workbench.editor.labelFormat": "medium",
    "workbench.sideBar.location": "right",
    "debug.breakpointsView.presentation": "tree",
    "ruff.configuration": "",
    "explorer.confirmDragAndDrop": false,
    "python.analysis.autoImportCompletions": true,
    "python.languageServer": "Pylance",
    "python.analysis.typeCheckingMode": "basic",
    "python.testing.pytestEnabled": true,
    "python.analysis.aiCodeActions": {
        "implementAbstractClasses": true,
        "generateSymbol": true,
        "convertFormatString": true
    }

